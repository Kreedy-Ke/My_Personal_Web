---
import { getCollection } from "astro:content";

const siteName = "My Personal Site";

const articles = (await getCollection("articles", ({ data }) => {
    return data.draft !== true;
})).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<html lang="zh-CN">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <title>Articles | {siteName}</title>
        <meta name="description" content="文章和笔记列表。" />
    </head>
    <body>
        <main class="page-shell">
            <a class="back-link" href="/">← Home</a>

            <header>
                <p class="eyebrow">Articles</p>
                <h1>文章</h1>
                <p class="intro">文章、笔记、长文和一些持续整理的想法。</p>
            </header>

            <section class="article-list">
                {articles.map((article) => (
                    <a class="article-card" href={`/articles/${article.id}/`}>
                        <div>
                            <h2>{article.data.title}</h2>
                            <p>{article.data.summary}</p>
                        </div>
                        <time datetime={article.data.date.toISOString()}>
                            {article.data.date.toLocaleDateString("zh-CN")}
                        </time>
                    </a>
                ))}
            </section>
        </main>
    </body>
</html>

<style>
    :global(*) {
        box-sizing: border-box;
    }

    :global(body) {
        margin: 0;
        min-height: 100vh;
        font-family:
            Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
            "Segoe UI", sans-serif;
        color: #1f2933;
        background: #f6f2ea;
    }

    .page-shell {
        width: min(860px, calc(100% - 32px));
        margin: 0 auto;
        padding: 64px 0;
    }

    .back-link {
        display: inline-block;
        margin-bottom: 40px;
        color: #4b5563;
        text-decoration: none;
    }

    .eyebrow {
        margin: 0 0 12px;
        font-size: 14px;
        text-transform: uppercase;
        color: #6b7280;
    }

    h1 {
        margin: 0;
        font-size: clamp(40px, 7vw, 72px);
        line-height: 1;
    }

    .intro {
        margin: 24px 0 40px;
        font-size: 20px;
        line-height: 1.7;
        color: #4b5563;
    }

    .article-list {
        display: grid;
        gap: 16px;
    }

    .article-card {
        display: flex;
        justify-content: space-between;
        gap: 24px;
        padding: 22px;
        border: 1px solid #d8d0c2;
        border-radius: 8px;
        color: inherit;
        text-decoration: none;
        background: #fffaf1;
    }

    .article-card:hover {
        border-color: #1f2933;
    }

    .article-card h2 {
        margin: 0 0 8px;
        font-size: 24px;
    }

    .article-card p {
        margin: 0;
        color: #4b5563;
        line-height: 1.7;
    }

    time {
        flex: 0 0 auto;
        color: #6b7280;
    }

    @media (max-width: 640px) {
        .article-card {
            display: block;
        }

        time {
            display: block;
            margin-top: 16px;
        }
    }
</style>