---
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
    const reviews = await getCollection("reviews", ({ data }) => {
        return data.draft !== true;
    });

    return reviews.map((review) => ({
        params: { id: review.id },
        props: { review },
    }));
}

const { review } = Astro.props;
const { Content } = await render(review);

const categoryLabels = {
    book: "书籍",
    movie: "电影",
    anime: "动画",
    game: "游戏",
    music: "音乐",
    art: "艺术",
    other: "其他",
};

const statusLabels = {
    planned: "想看",
    watching: "在看",
    reading: "在读",
    playing: "在玩",
    finished: "已完成",
    paused: "暂停",
    dropped: "放弃",
};
---

<html lang="zh-CN">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <title>{review.data.title}</title>
        <meta name="description" content={review.data.summary} />
    </head>
    <body>
        <main class="page-shell">
            <a class="back-link" href="/reviews/">← Reviews</a>

            <article>
                <header class="review-header">
                    {review.data.cover && (
                        <img
                            src={review.data.cover}
                            alt=""
                            loading="eager"
                        />
                    )}

                    <div>
                        <time datetime={review.data.date.toISOString()}>
                            {review.data.date.toLocaleDateString("zh-CN")}
                        </time>

                        <h1>{review.data.workTitle}</h1>

                        {review.data.originalTitle && (
                            <p class="original-title">{review.data.originalTitle}</p>
                        )}

                        <div class="review-meta">
                            <span>{categoryLabels[review.data.category]}</span>
                            <span>{statusLabels[review.data.status]}</span>
                            {review.data.year && <span>{review.data.year}</span>}
                            {review.data.rating !== undefined && (
                                <span>{review.data.rating}/10</span>
                            )}
                        </div>

                        <p class="summary">{review.data.summary}</p>

                        {review.data.externalUrl && (
                            <a class="external-link" href={review.data.externalUrl} target="_blank">
                                外部页面
                            </a>
                        )}
                    </div>
                </header>

                <div class="content">
                    <Content />
                </div>
            </article>
        </main>
    </body>
</html>

<style>
    :global(*) {
        box-sizing: border-box;
    }

    :global(body) {
        margin: 0;
        min-height: 100vh;
        font-family:
            Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
            "Segoe UI", sans-serif;
        color: #1f2933;
        background: #f6f2ea;
    }

    .page-shell {
        width: min(860px, calc(100% - 32px));
        margin: 0 auto;
        padding: 64px 0;
    }

    .back-link {
        display: inline-block;
        margin-bottom: 40px;
        color: #4b5563;
        text-decoration: none;
    }

    .review-header {
        display: grid;
        grid-template-columns: 180px 1fr;
        gap: 28px;
        align-items: start;
        margin-bottom: 48px;
    }

    .review-header img {
        width: 180px;
        border-radius: 8px;
    }

    time,
    .original-title {
        color: #6b7280;
    }

    h1 {
        margin: 14px 0 10px;
        font-size: clamp(36px, 6vw, 64px);
        line-height: 1.1;
    }

    .original-title {
        margin: 0;
        font-size: 18px;
    }

    .review-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin: 20px 0;
    }

    .review-meta span {
        padding: 4px 8px;
        border: 1px solid #d8d0c2;
        border-radius: 999px;
        font-size: 14px;
        color: #4b5563;
    }

    .summary {
        margin: 0;
        font-size: 18px;
        line-height: 1.7;
        color: #4b5563;
    }

    .external-link {
        display: inline-block;
        margin-top: 18px;
        color: #1f2933;
    }

    .content {
        font-size: 18px;
        line-height: 1.9;
    }

    .content :global(p) {
        margin: 0 0 20px;
    }

    @media (max-width: 680px) {
        .review-header {
            grid-template-columns: 1fr;
        }

        .review-header img {
            width: 140px;
        }
    }
</style>