---
import { getCollection } from "astro:content";

const siteName = "My Personal Site";

const reviews = (await getCollection("reviews", ({ data }) => {
    return data.draft !== true;
})).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categoryLabels = {
    book: "书籍",
    movie: "电影",
    anime: "动画",
    game: "游戏",
    music: "音乐",
    art: "艺术",
    other: "其他",
};

const statusLabels = {
    planned: "想看",
    watching: "在看",
    reading: "在读",
    playing: "在玩",
    finished: "已完成",
    paused: "暂停",
    dropped: "放弃",
};
---

<html lang="zh-CN">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <title>Reviews | {siteName}</title>
        <meta name="description" content="作品评价列表。" />
    </head>
    <body>
        <main class="page-shell">
            <a class="back-link" href="/">← Home</a>

            <header>
                <p class="eyebrow">Reviews</p>
                <h1>作品评价</h1>
                <p class="intro">书、电影、动画、游戏、音乐和其他作品的记录与评价。</p>
            </header>

            <section class="review-list">
                {reviews.map((review) => (
                    <a class="review-card" href={`/reviews/${review.id}/`}>
                        {review.data.cover ? (
                            <img
                                src={review.data.cover}
                                alt=""
                                loading="lazy"
                            />
                        ) : (
                            <div class="cover-placeholder">
                                {categoryLabels[review.data.category]}
                            </div>
                        )}

                        <div class="review-body">
                            <div class="review-title">
                                <h2>{review.data.workTitle}</h2>
                                {review.data.originalTitle && (
                                    <p>{review.data.originalTitle}</p>
                                )}
                            </div>

                            <div class="review-meta">
                                <span>{categoryLabels[review.data.category]}</span>
                                <span>{statusLabels[review.data.status]}</span>
                                {review.data.year && <span>{review.data.year}</span>}
                                {review.data.rating !== undefined && (
                                    <span>{review.data.rating}/10</span>
                                )}
                            </div>

                            <p class="summary">{review.data.summary}</p>
                        </div>
                    </a>
                ))}
            </section>
        </main>
    </body>
</html>

<style>
    :global(*) {
        box-sizing: border-box;
    }

    :global(body) {
        margin: 0;
        min-height: 100vh;
        font-family:
            Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
            "Segoe UI", sans-serif;
        color: #1f2933;
        background: #f6f2ea;
    }

    .page-shell {
        width: min(920px, calc(100% - 32px));
        margin: 0 auto;
        padding: 64px 0;
    }

    .back-link {
        display: inline-block;
        margin-bottom: 40px;
        color: #4b5563;
        text-decoration: none;
    }

    .eyebrow {
        margin: 0 0 12px;
        font-size: 14px;
        text-transform: uppercase;
        color: #6b7280;
    }

    h1 {
        margin: 0;
        font-size: clamp(40px, 7vw, 72px);
        line-height: 1;
    }

    .intro {
        margin: 24px 0 40px;
        font-size: 20px;
        line-height: 1.7;
        color: #4b5563;
    }

    .review-list {
        display: grid;
        gap: 16px;
    }

    .review-card {
        display: grid;
        grid-template-columns: 112px 1fr;
        gap: 20px;
        padding: 18px;
        border: 1px solid #d8d0c2;
        border-radius: 8px;
        color: inherit;
        text-decoration: none;
        background: #fffaf1;
    }

    .review-card:hover {
        border-color: #1f2933;
    }

    .review-card img,
    .cover-placeholder {
        width: 112px;
        height: 156px;
        border-radius: 6px;
        object-fit: cover;
        background: #e8dfcf;
    }

    .cover-placeholder {
        display: grid;
        place-items: center;
        padding: 12px;
        text-align: center;
        color: #6b7280;
    }

    .review-title h2 {
        margin: 0 0 6px;
        font-size: 24px;
    }

    .review-title p {
        margin: 0;
        color: #6b7280;
    }

    .review-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin: 16px 0;
    }

    .review-meta span {
        padding: 4px 8px;
        border: 1px solid #d8d0c2;
        border-radius: 999px;
        font-size: 14px;
        color: #4b5563;
    }

    .summary {
        margin: 0;
        line-height: 1.7;
        color: #4b5563;
    }

    @media (max-width: 640px) {
        .review-card {
            grid-template-columns: 80px 1fr;
            gap: 14px;
        }

        .review-card img,
        .cover-placeholder {
            width: 80px;
            height: 112px;
        }
    }
</style>