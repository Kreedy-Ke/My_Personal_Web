---
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
    const articles = await getCollection("articles", ({ data }) => {
        return data.draft !== true;
    });

    return articles.map((article) => ({
        params: { id: article.id },
        props: { article },
    }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const writtenDate = article.data.writtenDate ?? article.data.date;
const hasSeparateWrittenDate = article.data.writtenDate !== undefined;
---

<html lang="zh-CN">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <title>{article.data.title}</title>
        <meta name="description" content={article.data.summary} />
    </head>
    <body>
        <main class="page-shell">
            <a class="back-link" href="/articles/">← Articles</a>

            <article>
                <header>
                    <div class="date-line">
                        {hasSeparateWrittenDate ? (
                            <>
                                <span>
                                    写于 <time datetime={writtenDate.toISOString()}>
                                        {writtenDate.toLocaleDateString("zh-CN")}
                                    </time>
                                </span>
                                <span>
                                    发布于 <time datetime={article.data.date.toISOString()}>
                                        {article.data.date.toLocaleDateString("zh-CN")}
                                    </time>
                                </span>
                            </>
                        ) : (
                            <span>
                                发布于 <time datetime={article.data.date.toISOString()}>
                                    {article.data.date.toLocaleDateString("zh-CN")}
                                </time>
                            </span>
                        )}
                    </div>
                    <h1>{article.data.title}</h1>
                    <p class="summary">{article.data.summary}</p>
                </header>

                <div class="content">
                    <Content />
                </div>
            </article>
        </main>
    </body>
</html>

<style>
    :global(*) {
        box-sizing: border-box;
    }

    :global(body) {
        margin: 0;
        min-height: 100vh;
        font-family:
            Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
            "Segoe UI", sans-serif;
        color: #1f2933;
        background: #f6f2ea;
    }

    .page-shell {
        width: min(760px, calc(100% - 32px));
        margin: 0 auto;
        padding: 64px 0;
    }

    .back-link {
        display: inline-block;
        margin-bottom: 40px;
        color: #4b5563;
        text-decoration: none;
    }

    .date-line {
        display: flex;
        flex-wrap: wrap;
        gap: 8px 20px;
        color: #6b7280;
    }

    h1 {
        margin: 16px 0;
        font-size: clamp(38px, 6vw, 64px);
        line-height: 1.1;
    }

    .summary {
        margin: 0 0 48px;
        font-size: 20px;
        line-height: 1.7;
        color: #4b5563;
    }

    .content {
        font-size: 18px;
        line-height: 1.9;
    }

    .content :global(p) {
        margin: 0 0 20px;
    }
</style>
