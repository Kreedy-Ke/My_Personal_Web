---
const siteName = "苗の小屋";

const sections = [
    {
        title: "Articles",
        href: "/articles/",
        description: "文章、笔记、长文和一些持续整理的想法。",
    },
    {
        title: "Gallery",
        href: "/gallery/",
        description: "图片集、摄影、截图和视觉记录。",
    },
    {
        title: "Reviews",
        href: "/reviews/",
        description: "对书、电影、动画、游戏、音乐和他人作品的评价。",
    },
];
---

<html lang="zh-CN">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <title>{siteName}</title>
        <meta
            name="description"
            content="一个用于存放文章、图片集、作品评价和个人档案的个人站。"
        />
    </head>
    <body>
        <main class="site-shell">
            <header class="hero">
                <p class="eyebrow">Personal Site</p>
                <div class="title-row">
                    <h1>{siteName}</h1>
                    <a class="about-link" href="/about/">About</a>
                </div>
                <p class="intro">
                    这里会存放我的文章、图片集、作品评价，以及一些长期整理的个人档案。
                </p>
            </header>

            <section class="section-grid" aria-label="站点栏目">
                {sections.map((section) => (
                    <a class="section-card" href={section.href}>
                        <h2>{section.title}</h2>
                        <p>{section.description}</p>
                    </a>
                ))}
            </section>

            <section class="recent">
                <h2>Recent Updates</h2>
                <p>这里之后会显示最近发布的文章、图片集和评价。</p>
            </section>
        </main>
    </body>
</html>

<style>
    :global(*) {
        box-sizing: border-box;
    }

    :global(body) {
        margin: 0;
        min-height: 100vh;
        font-family:
            Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
            "Segoe UI", sans-serif;
        color: #1f2933;
        background: #f6f2ea;
    }

    .site-shell {
        width: min(1080px, calc(100% - 32px));
        margin: 0 auto;
        padding: 72px 0;
    }

    .hero {
        max-width: 760px;
        margin-bottom: 40px;
    }

    .eyebrow {
        margin: 0 0 12px;
        font-size: 14px;
        letter-spacing: 0;
        text-transform: uppercase;
        color: #6b7280;
    }

    h1 {
        margin: 0;
        font-size: clamp(40px, 7vw, 84px);
        line-height: 1;
    }

    .title-row {
        display: flex;
        gap: 18px;
        align-items: baseline;
    }

    .about-link {
        font-size: 14px;
        color: #6b7280;
        text-decoration: none;
    }

    .about-link:hover {
        color: #1f2933;
        text-decoration: underline;
        text-underline-offset: 4px;
    }

    .intro {
        max-width: 640px;
        margin: 24px 0 0;
        font-size: 20px;
        line-height: 1.7;
        color: #4b5563;
    }

    .section-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
        margin-top: 48px;
    }

    .section-card,
    .recent {
        border: 1px solid #d8d0c2;
        border-radius: 8px;
        background: #fffaf1;
    }

    .section-card {
        min-height: 180px;
        padding: 22px;
        color: inherit;
        text-decoration: none;
    }

    .section-card:hover {
        border-color: #1f2933;
    }

    .section-card h2,
    .recent h2 {
        margin: 0 0 12px;
        font-size: 22px;
    }

    .section-card p,
    .recent p {
        margin: 0;
        line-height: 1.7;
        color: #4b5563;
    }

    .recent {
        margin-top: 16px;
        padding: 24px;
    }

    @media (max-width: 860px) {
        .section-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @media (max-width: 560px) {
        .site-shell {
            width: min(100% - 24px, 1080px);
            padding: 40px 0;
        }

        .section-grid {
            grid-template-columns: 1fr;
        }

        .intro {
            font-size: 17px;
        }
    }
</style>
